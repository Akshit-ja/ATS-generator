# Enhanced AI Configuration - Multiple Provider Support
# Choose any AI provider by setting AI_PROVIDER and the corresponding API key

# =============================================================================
# AI PROVIDER CONFIGURATION
# =============================================================================
# Set AI_PROVIDER to one of: openai, anthropic, google, ollama
AI_PROVIDER=openai

# =============================================================================
# API KEYS (Set the one for your chosen provider)
# =============================================================================

# OpenAI API Key (for ChatGPT, GPT-4, etc.)
AI_API_KEY=your-openai-api-key-here
# Alternative: You can still use OPENAI_API_KEY (for backward compatibility)
OPENAI_API_KEY=your-openai-api-key-here

# Anthropic API Key (for Claude models)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Google API Key (for Gemini models)  
GOOGLE_API_KEY=your-google-api-key-here

# =============================================================================
# CUSTOM MODEL CONFIGURATION (Optional)
# =============================================================================
# Override default models for specific tasks

# OpenAI Models (if using OpenAI)
AI_MODEL_RESUME=gpt-4o-mini          # or gpt-3.5-turbo, gpt-4, gpt-4-turbo
AI_MODEL_INTERVIEW=gpt-3.5-turbo     # or gpt-4o-mini
AI_MODEL_ENHANCE=gpt-4o-mini         # or gpt-4-turbo
AI_MODEL_MATCHING=gpt-3.5-turbo      # or gpt-4o-mini

# Anthropic Models (if using Anthropic)
# AI_MODEL_RESUME=claude-3-5-sonnet-20241022    # or claude-3-haiku-20240307
# AI_MODEL_INTERVIEW=claude-3-haiku-20240307    # or claude-3-5-sonnet-20241022
# AI_MODEL_ENHANCE=claude-3-5-sonnet-20241022
# AI_MODEL_MATCHING=claude-3-haiku-20240307

# Google Models (if using Google)
# AI_MODEL_RESUME=gemini-1.5-pro        # or gemini-1.5-flash
# AI_MODEL_INTERVIEW=gemini-1.5-flash   # or gemini-1.5-pro
# AI_MODEL_ENHANCE=gemini-1.5-pro
# AI_MODEL_MATCHING=gemini-1.5-flash

# Ollama Models (if using Ollama - local AI)
# AI_MODEL_RESUME=llama3.1              # or codellama, mistral, etc.
# AI_MODEL_INTERVIEW=llama3.1
# AI_MODEL_ENHANCE=llama3.1
# AI_MODEL_MATCHING=llama3.1

# =============================================================================
# OLLAMA CONFIGURATION (if using Ollama)
# =============================================================================
# Ollama base URL (if running locally)
AI_BASE_URL=http://localhost:11434

